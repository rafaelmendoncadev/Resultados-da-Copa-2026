<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="6dp">

    <TextView
        android:id="@+id/positionText"
        android:layout_width="24dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/wc_text_primary" />

    <TextView
        android:id="@+id/teamText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="13sp"
        android:textColor="@color/wc_text_primary"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/mpText"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:gravity="center"
        android:textColor="@color/wc_text_secondary" />

    <TextView
        android:id="@+id/gdText"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:gravity="center"
        android:textColor="@color/wc_text_secondary" />

    <TextView
        android:id="@+id/ptsText"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/wc_green_dark" />

</LinearLayout>
